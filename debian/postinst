#!/bin/bash
set -e

# Install Python dependencies into the app's own lib directory using system Python
/usr/bin/python3 -m pip install --target=/opt/screen-translator/lib deep-translator>=1.11.4 gTTS>=2.3.2 2>/dev/null || \
/usr/bin/pip3 install --target=/opt/screen-translator/lib deep-translator>=1.11.4 gTTS>=2.3.2 2>/dev/null || \
echo "Warning: Could not install dependencies. Please run: /usr/bin/python3 -m pip install deep-translator gTTS"

echo "Screen Translator installed successfully."
echo "Launch from Applications menu or run: screen-translator"
